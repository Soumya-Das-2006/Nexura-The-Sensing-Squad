# ================================================================
# Nexura — Environment Variables
# Copy this to .env and fill in your values.
# Leave API keys blank to use sandbox/mock mode.
# ================================================================

# Django Core
SECRET_KEY=your-50-char-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database ──────────────────────────────────────────────────────
# Leave DB_NAME empty to use SQLite (recommended for local dev)
# Set to your PostgreSQL database name for production
DB_NAME=
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# ── Redis & Celery ────────────────────────────────────────────────
# Redis is required for: platform uptime tracker, Celery broker, cache
# Install: Windows → Memurai or WSL redis-server; Mac → brew install redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── Weather & AQI APIs ────────────────────────────────────────────
# Leave blank for realistic mock data (sandbox mode)
OPENWEATHER_API_KEY=your_openweathermap_api_key_hereyour_openweathermap_api_key_here
WAQI_API_KEY=

# ── Razorpay ─────────────────────────────────────────────────────
# Leave blank for full sandbox simulation
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_ACCOUNT_NUMBER=
RAZORPAY_WEEKLY_PLAN_ID=

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────
# Leave blank — notifications logged to console in mock mode
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=nexura_verify

# ── Twilio (OTP SMS) ─────────────────────────────────────────────
# Leave blank — OTP printed to console in test mode
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── SendGrid (Email) ─────────────────────────────────────────────
# Leave blank — emails logged to console in dev
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=noreply@nexaura.in

# ── AWS S3 (IncomeDNA document storage) ──────────────────────────
# Leave blank — PDFs saved locally to media/ in dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=nexaura-documents
AWS_S3_REGION_NAME=ap-south-1

# OTP Settings — in test mode, check Django server console for the code
OTP_EXPIRY_MINUTES=10
OTP_TEST_MODE=True
OTP_TEST_CODE=123456

# ── Frontend ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Chatbot LLM Providers ─────────────────────────────────────────
CHATBOT_LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=